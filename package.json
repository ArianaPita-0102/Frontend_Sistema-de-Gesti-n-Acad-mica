{
  "name": "sistema-gestion-academica",
  "version": "1.0.0",
  "description": "Sistema de Gestión Académica - UCB San Pablo",
  "scripts": {
    "build:ts": "tsc",
    "build:scss": "sass scss/styles.scss css/styles.css",
    "watch:ts": "tsc --watch",
    "watch:scss": "sass --watch scss/styles.scss:css/styles.css",
    "dev": "concurrently \"npm run watch:ts\" \"npm run watch:scss\" \"live-server --port=3000\"",
    "build": "npm run build:ts && npm run build:scss"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "sass": "^1.75.0",
    "concurrently": "^8.2.0",
    "live-server": "^1.2.2"
  }
}